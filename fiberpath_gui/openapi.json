  "openapi": "3.1.0",
  "paths": {
    "/health": {
      "get": {
        "description": "Liveness probe the sidecar supervisor polls for readiness.",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Health Health Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Health",
        "tags": [
          "meta"
        ]
      }
    },
    "/machine/commands": {
      "post": {
        "description": "Run a single manual G-code command (rejected 409 while a job streams).",
        "operationId": "send_command_machine_commands_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CommandRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CommandResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Input rejected by the compute engine."
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Send Command",
        "tags": [
          "machine"
        ]
      }
    },
    "/machine/connection": {
      "delete": {
        "description": "Cancel any active job and close the serial port.",
        "operationId": "disconnect_machine_connection_delete",
        "responses": {
          "204": {
            "description": "Successful Response"
          }
        },
        "summary": "Disconnect",
        "tags": [
          "machine"
        ]
      },
      "post": {
        "description": "Open the serial port and return the controller's connection banner.",
        "operationId": "connect_machine_connection_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ConnectRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConnectionInfoOut"
                }
              }
            },
            "description": "Successful Response"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Input rejected by the compute engine."
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Connect",
        "tags": [
          "machine"
        ]
      }
    },
    "/machine/estop": {
      "post": {
        "description": "Issue #196 safety stop: write M112 out-of-band, bypassing the lock.",
        "operationId": "emergency_stop_machine_estop_post",
        "responses": {
          "204": {
            "description": "Successful Response"
          }
        },
        "summary": "Emergency Stop",
        "tags": [
          "machine"
        ]
      }
    },
    "/machine/jobs": {
      "post": {
        "description": "Start streaming a G-code program on a background worker.",
        "operationId": "start_job_machine_jobs_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StartJobRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StartJobResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Input rejected by the compute engine."
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Start Job",
        "tags": [
          "machine"
        ]
      }
    },
    "/machine/jobs/{job_id}": {
      "get": {
        "description": "Poll a job's status and the event log entries with ``seq > since``.",
        "operationId": "get_job_machine_jobs__job_id__get",
        "parameters": [
          {
            "in": "path",
            "name": "job_id",
            "required": true,
            "schema": {
              "title": "Job Id",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "since",
            "required": false,
            "schema": {
              "default": 0,
              "title": "Since",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobStatusOut"
                }
              }
            },
            "description": "Successful Response"
          },
