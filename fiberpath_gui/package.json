{
  "name": "fiberpath-gui",
  "version": "0.5.4",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0 <25.0.0",
    "npm": ">=11.0.0 <12.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:css:vars": "node scripts/check-css-vars.mjs",
    "lint:css:fix": "stylelint \"src/**/*.css\" --fix",
    "format:check": "cd src-tauri && cargo fmt --check",
    "format:fix": "cd src-tauri && cargo fmt",
    "clippy": "cd src-tauri && cargo clippy -- -D warnings",
    "check:all": "npm run lint && npm run lint:css && npm run lint:css:vars && npm run format:check && npm run clippy",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "tauri": "tauri",
    "package": "tauri build --ci",
    "schema:generate": "python ../scripts/generate_schema.py && npx json-schema-to-typescript schemas/wind-schema.json > src/types/wind-schema.ts"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-menubar": "^1.1.16",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "clsx": "^2.1.0",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.0.0",
    "react-zoom-pan-pinch": "^3.7.0",
    "zod": "^4.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "ajv": "^8.18.0",
    "jsdom": "^29.0.0",
    "json-schema-to-typescript": "^15.0.4",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.5",
    "vitest": "^4.0.0"
  }
}
